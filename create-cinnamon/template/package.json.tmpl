{
  "name": "{{PROJECT_NAME}}",
  "version": "0.0.1",
  "description": "Job orchestration powered by Cinnamon (BullMQ, Postgres, Hono)",
  "main": "src/index.ts",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run db/migrate.ts",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit && tsc -p src/dashboard/tsconfig.json --noEmit",
    "generate:secret": "openssl rand -base64 32",
    "seed:team": "bun run scripts/seed-team.ts",
    "scheduler": "bun run src/scheduler.ts",
    "server": "bun run --watch src/server.ts",
    "worker": "bun run --watch src/worker.ts",
    "dev:dashboard": "vite",
    "build:dashboard": "vite build",
    "dev": "trap 'kill 0' EXIT; bun run --watch src/server.ts & vite & wait"
  },
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "bullmq": "^5.67.3",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "figlet": "^1.11.0",
    "hono": "^4.12.5",
    "jose": "^6.2.0",
    "nanoid": "^5.1.6",
    "ioredis": "^5.4.2",
    "pg": "^8.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.2.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
