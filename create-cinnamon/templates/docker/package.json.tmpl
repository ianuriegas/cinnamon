{
  "name": "{{PROJECT_NAME}}",
  "version": "0.0.1",
  "private": true,
  "description": "Job orchestration powered by Cinnamon",
  "scripts": {
    "deploy": "docker compose up -d --build --force-recreate && docker image prune -f",
    "dev": "docker compose up --pull always",
    "worker": "docker compose up worker",
    "scheduler": "docker compose up scheduler",
    "server": "docker compose up api",
    "db:migrate": "docker compose run -T --rm migrate",
    "db:generate": "bunx drizzle-kit generate --config db/drizzle.config.ts",
    "db:drop": "bunx drizzle-kit drop --config db/drizzle.config.ts",
    "seed:team": "docker compose run -T --rm api bun run seed:team",
    "generate:secret": "openssl rand -base64 32",
    "logs": "docker compose logs -f",
    "down": "docker compose down",
    "pull": "docker compose pull"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/pg": "^8.16.0"
  }
}
