{
  "name": "cinnamon",
  "version": "1.0.0",
  "description": "Job orchestration framework powered by BullMQ, Postgres, and Hono.",
  "main": "src/index.ts",
  "scripts": {
    "clean": "rm -rf node_modules",
    "cli": "bun run cli/index.ts",
    "db:drop": "bun run scripts/db-drop.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run db/migrate.ts",
    "cinnamon:migrate": "bun run db/migrate.ts",
    "db:reset-local": "bun run scripts/db-reset-local.ts",
    "format": "biome format --write .",
    "job": "bun run scripts/run-jobs.ts",
    "job:cinnamon": "bun run jobs/cinnamon/index.ts",
    "job:dry": "bun run scripts/run-jobs.ts --dry",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "NODE_ENV=test bun test",
    "trigger": "bun run src/index.ts",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.dashboard.json --noEmit",
    "generate:secret": "openssl rand -base64 32",
    "scheduler": "bun run src/scheduler.ts",
    "server": "bun run --watch src/server.ts",
    "worker": "bun run --watch src/worker.ts",
    "dev:dashboard": "vite",
    "build:dashboard": "vite build",
    "dev": "bun run --watch src/server.ts & vite"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ianuriegas/cinnamon.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bin": {
    "cinnamon": "cli/index.ts"
  },
  "bugs": {
    "url": "https://github.com/ianuriegas/cinnamon/issues"
  },
  "homepage": "https://github.com/ianuriegas/cinnamon#readme",
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "bullmq": "^5.67.3",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "jose": "^6.2.0",
    "pg": "^8.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@clack/prompts": "^1.1.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.2.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
