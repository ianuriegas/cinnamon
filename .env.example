# ── Server ────────────────────────────────────────────────────────────
# PORT=3000

# ── Scheduler ────────────────────────────────────────────────────────
# When true, scheduled (cron) jobs run in dry-run mode (--dry-run flag).
# Manual triggers via CLI or dashboard run normally. Useful for local dev.
# DISABLE_CRON_JOBS=true

# ── CLI ──────────────────────────────────────────────────────────────
# Override ~/.cinnamon/config.json with env vars
# CINNAMON_API_URL=http://localhost:3000
# CINNAMON_API_KEY=cin_...

# ── Infrastructure (Postgres + Redis) ─────────────────────────────────
# Used by docker-compose.yml to configure the postgres container and
# build DATABASE_URL / REDIS_URL for the app services.
# For local (non-Docker) dev, DATABASE_URL and REDIS_URL point at localhost.
POSTGRES_USER=cinnamon
POSTGRES_PASSWORD=change-me
POSTGRES_DB=cinnamon
DATABASE_URL=postgresql://cinnamon:change-me@localhost:5432/cinnamon
REDIS_URL=redis://localhost:6379

# ── Webhooks ──────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ── Dashboard OAuth ───────────────────────────────────────────────────
# Auth is enabled when SESSION_SECRET is set and Google creds are available.
# Google creds are loaded from client_secret.json (GCP download) automatically,
# or you can set GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET here to override.
# Generate a session secret: bun run generate:secret
# GOOGLE_CLIENT_ID=                          # optional if client_secret.json exists
# GOOGLE_CLIENT_SECRET=                      # optional if client_secret.json exists
# BASE_URL: use http://localhost:3000 for Docker/production (built dashboard on :3000).
# SESSION_SECRET=                            # run: bun run generate:secret
# ALLOWED_EMAILS=user@gmail.com,other@gmail.com  # comma-separated; unset = open access
#
# Optional: .env.local (gitignored) overrides .env when running `bun run dev`.
# Use it for local-only values, e.g. BASE_URL=http://localhost:5173 for Vite OAuth.
