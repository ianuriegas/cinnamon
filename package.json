{
  "name": "cinnamon",
  "version": "1.0.0",
  "description": "Backend-first BullMQ demo with Postgres job logs.",
  "main": "src/index.ts",
  "scripts": {
    "clean": "rm -rf node_modules",
    "db:drop": "bun run scripts/db-drop.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run db/migrate.ts",
    "db:reset-local": "bun run scripts/db-reset-local.ts",
    "format": "biome format --write .",
    "job": "bun run scripts/run-jobs.ts",
    "job:cinnamon": "bun run jobs/cinnamon/index.ts",
    "job:dry": "bun run scripts/run-jobs.ts --dry",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test",
    "trigger": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "auth:spotify": "bun run scripts/spotify-auth.ts",
    "scheduler": "bun run src/scheduler.ts",
    "server": "bun run src/server.ts",
    "worker": "bun run src/worker.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ianuriegas/cinnamon.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/ianuriegas/cinnamon/issues"
  },
  "homepage": "https://github.com/ianuriegas/cinnamon#readme",
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "bullmq": "^5.67.3",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@clack/prompts": "^1.1.0",
    "@types/node": "^25.2.2",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.3"
  }
}
