# ── Infrastructure ────────────────────────────────────────────────────
POSTGRES_USER=cinnamon
POSTGRES_PASSWORD=change-me
POSTGRES_DB=cinnamon
DATABASE_URL=postgresql://cinnamon:change-me@localhost:5432/cinnamon
REDIS_URL=redis://localhost:6379

# ── Scheduler ────────────────────────────────────────────────────────
# When true, scheduled (cron) jobs run in dry-run mode.
# Manual triggers via CLI or dashboard run normally.
# DISABLE_CRON_JOBS=true

# ── Webhooks ─────────────────────────────────────────────────────────
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=

# ── Dashboard OAuth ──────────────────────────────────────────────────
# Auth is enabled when SESSION_SECRET is set and Google creds are available.
# Generate a session secret: cd cinnamon && bun run generate:secret
# SESSION_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# BASE_URL=http://localhost:3000
# SUPER_ADMINS=you@gmail.com
# ACCESS_REQUESTS_ENABLED=true
