# ── Infrastructure ────────────────────────────────────────────────────
# These Postgres credentials are used by docker-compose.yml to create the
# database container. DATABASE_URL and REDIS_URL below are for host-side
# tools only (e.g. psql from your machine) — inside Docker they are
# overridden by docker-compose.yml with container-internal addresses.
POSTGRES_USER=cinnamon
POSTGRES_PASSWORD=change-me
POSTGRES_DB=cinnamon
DATABASE_URL=postgresql://cinnamon:change-me@localhost:5432/cinnamon
REDIS_URL=redis://localhost:6379

# ── Cinnamon image version ───────────────────────────────────────────
# CINNAMON_VERSION=latest

# ── Scheduler ────────────────────────────────────────────────────────
# When true, scheduled (cron) jobs run in dry-run mode.
# Manual triggers via CLI or dashboard run normally.
# DISABLE_CRON_JOBS=true

# ── Webhooks ─────────────────────────────────────────────────────────
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=

# ── Dashboard OAuth ──────────────────────────────────────────────────
# Auth is enabled when SESSION_SECRET is set and Google creds are available.
# Generate a session secret: bun run generate:secret
# SESSION_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# BASE_URL=http://localhost:3000
# SUPER_ADMINS=you@gmail.com
# ACCESS_REQUESTS_ENABLED=true
