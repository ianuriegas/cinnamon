POSTGRES_USER=cinnamon
POSTGRES_PASSWORD=change-me
POSTGRES_DB=cinnamon
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://cinnamon:change-me@localhost:5432/cinnamon

# WEBHOOKS (used in cinnamon.config.ts notification URLs)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# SPOTIFY AUTH
# Option 1: Static access token (short-lived, good for testing)
SPOTIFY_ACCESS_TOKEN=
# Option 2: Auto-refresh via client credentials (recommended for production)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
